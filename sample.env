# Entropic Atlas Configuration
# Copy to .env and fill in your API keys

# LLM Provider API Keys (at least one required)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (optional)
# ATLAS_FAST_MODEL=openai/gpt-4.1-mini
# ATLAS_STANDARD_MODEL=openai/gpt-4.1
# ATLAS_STRONG_MODEL=anthropic/claude-sonnet-4-6
# ATLAS_VISION_MODEL=openai/gpt-4.1
