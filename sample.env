# Spatial Atlas Configuration
# Copy to .env and fill in your API keys.
# The strong tier defaults to Claude Opus 4.6, so both keys are required
# for the default config. Drop ANTHROPIC_API_KEY and override
# ATLAS_STRONG_MODEL=openai/gpt-4.1 to run OpenAI-only.

# LLM Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (optional; defaults shown)
# ATLAS_FAST_MODEL=openai/gpt-4.1-mini
# ATLAS_STANDARD_MODEL=openai/gpt-4.1
# ATLAS_STRONG_MODEL=anthropic/claude-opus-4-6
# ATLAS_VISION_MODEL=openai/gpt-4.1
